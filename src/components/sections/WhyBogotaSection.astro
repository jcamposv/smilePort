---
import { getData, type Lang } from "../../data/i18n";

interface Props { lang?: Lang; }
const { lang = "en" } = Astro.props;
const { whyBogota } = getData(lang);

const icons: Record<string, string> = {
  dollar: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  shield: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
  building: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
  globe: "M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9",
};
---

<section class="py-20 lg:py-28 bg-white" id={lang === "en" ? "why-bogota" : "por-que-bogota"}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center mb-16 lg:mb-24">
      <span class="inline-flex items-center gap-2 bg-teal/10 text-teal-dark text-sm font-semibold px-4 py-1.5 rounded-full mb-5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9"/></svg>
        {lang === "en" ? "Top Dental Tourism Destination" : "Destino Top de Turismo Dental"}
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight text-navy">
        {lang === "en" ? "Why Bogotá?" : "¿Por qué Bogotá?"}
      </h2>
      <p class="mt-5 text-navy/50 text-lg font-body max-w-2xl mx-auto">
        {lang === "en" ? "Colombia is one of the top destinations for dental tourism worldwide — here's why thousands of Americans choose Bogotá every year." : "Colombia es uno de los principales destinos de turismo dental en el mundo — aquí te explicamos por qué miles de personas eligen Bogotá cada año."}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {whyBogota.items.map((item) => (
        <div class="group text-center p-8 rounded-3xl bg-offwhite hover:bg-cream transition-colors duration-500">
          <div class="w-14 h-14 mx-auto rounded-2xl bg-primary/10 group-hover:bg-primary flex items-center justify-center transition-colors duration-500 mb-5">
            <svg class="w-6 h-6 text-primary group-hover:text-white transition-colors duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={icons[item.icon]} />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-navy mb-2">{item.title}</h3>
          <p class="text-sm text-navy/50 leading-relaxed font-body">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

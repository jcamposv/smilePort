---
import { getData, type Lang } from "../../data/i18n";

interface Props { lang?: Lang; }
const { lang = "en" } = Astro.props;
const { team } = getData(lang);
---

<section class="py-20 lg:py-28 bg-cream" id={lang === "en" ? "team" : "equipo"}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center mb-16 lg:mb-24">
      <span class="inline-flex items-center gap-2 bg-teal/10 text-teal-dark text-sm font-semibold px-4 py-1.5 rounded-full mb-5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        {lang === "en" ? "Board-Certified Professionals" : "Profesionales Certificados"}
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight text-navy">
        {lang === "en" ? "Meet Our Specialists" : "Conoce a Nuestros Especialistas"}
      </h2>
      <p class="mt-5 text-navy/50 text-lg font-body max-w-2xl mx-auto">{lang === "en" ? "Internationally trained professionals with decades of experience and thousands of successful treatments." : "Profesionales con formación internacional, décadas de experiencia y miles de tratamientos exitosos."}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {team.map((doc) => (
        <div class="bg-white rounded-2xl overflow-hidden hover:shadow-xl transition-shadow duration-500">
          <div class="aspect-[4/3] overflow-hidden">
            <img src={doc.image} alt={doc.name} class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="p-6 lg:p-8">
            <h3 class="text-xl font-bold text-navy">{doc.name}</h3>
            <p class="text-teal text-sm font-semibold mt-1">{doc.specialty}</p>
            <p class="text-navy/50 text-sm leading-relaxed font-body mt-3">{doc.bio}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

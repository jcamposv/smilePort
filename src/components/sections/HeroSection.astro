---
import { getData, type Lang } from "../../data/i18n";

interface Props { lang?: Lang; }
const { lang = "en" } = Astro.props;
const { hero, stats } = getData(lang);
---

<section class="relative bg-navy overflow-hidden" id={lang === "en" ? "home" : "inicio"}>
  <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full border border-white/5 -translate-y-1/2 translate-x-1/4"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 lg:pt-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
      <!-- Text -->
      <div class="relative z-10 pb-8 lg:pb-16">
        <!-- Savings badge -->
        <div class="inline-flex items-center gap-2 bg-teal/20 text-teal-light text-sm font-semibold px-4 py-1.5 rounded-full mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8V7m0 10v1"/></svg>
          {lang === "en" ? "Save up to 70% vs. US prices" : "Ahorra hasta 70% vs. precios en EE.UU."}
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-white tracking-tight leading-[1.05]">
          {hero.headline.line1}<br />
          <span class="accent-font font-normal text-teal">{hero.headline.accent}</span>{" "}
          {hero.headline.line2}
        </h1>

        <div class="flex items-center gap-6 mt-10">
          <button data-booking class="group shrink-0 bg-teal text-white font-semibold rounded-full px-8 py-4 text-base hover:bg-teal-dark transition-all shadow-lg shadow-teal/20 cursor-pointer">
            {hero.cta.primary}
          </button>
          <p class="text-white/60 text-base lg:text-lg leading-relaxed font-body max-w-md">
            {hero.description}
          </p>
        </div>
      </div>

      <!-- Hero image -->
      <div class="relative lg:mt-0 -mt-2">
        <div class="relative rounded-2xl lg:rounded-3xl overflow-hidden aspect-[4/5] sm:aspect-[3/4] shadow-2xl shadow-black/20">
          <img src={hero.image} alt="Modern dental clinic in Bogotá" class="w-full h-full object-cover" loading="eager" />
          <div class="absolute bottom-4 left-4 bg-navy/90 backdrop-blur-sm rounded-lg px-4 py-2.5 flex items-center gap-2">
            <div class="flex gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3.5 h-3.5 text-teal" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            <span class="text-white text-xs font-medium">{lang === "en" ? "4.9 | 3,000+ patients" : "4.9 | 3,000+ pacientes"}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="border-t border-white/15 mt-8 lg:mt-12 py-8 lg:py-10">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-0">
        {stats.map((stat, i) => (
          <div class:list={["text-center lg:text-left", i < stats.length - 1 && "lg:border-r lg:border-white/15 lg:pr-8", i > 0 && "lg:pl-8"]}>
            <span class="block text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-none">{stat.value}</span>
            <span class="text-xs uppercase tracking-[2px] text-white/50 font-semibold mt-2 block">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

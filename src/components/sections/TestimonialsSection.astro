---
import { getData, type Lang } from "../../data/i18n";

interface Props { lang?: Lang; }
const { lang = "en" } = Astro.props;
const { testimonials } = getData(lang);
---

<section class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center mb-16 lg:mb-24">
      <span class="inline-flex items-center gap-2 bg-teal/10 text-teal-dark text-sm font-semibold px-4 py-1.5 rounded-full mb-5">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
        {lang === "en" ? "4.9 Average Rating" : "Calificación Promedio 4.9"}
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight text-navy">
        {lang === "en" ? "What Our Patients Say" : "Lo Que Dicen Nuestros Pacientes"}
      </h2>
      <p class="mt-5 text-navy/50 text-lg font-body max-w-2xl mx-auto">{lang === "en" ? "Real stories from patients who traveled to Bogotá for their dream smile." : "Historias reales de pacientes que viajaron a Bogotá por la sonrisa de sus sueños."}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {testimonials.map((t) => (
        <article class="bg-offwhite rounded-3xl p-8 lg:p-10 hover:shadow-lg transition-shadow duration-500">
          <div class="flex gap-1 mb-5">
            {Array.from({ length: t.rating }).map(() => (
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            ))}
          </div>
          <p class="text-navy/70 leading-relaxed font-body mb-6">"{t.review}"</p>
          <div class="flex items-center gap-3 pt-5 border-t border-gray-200/60">
            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
              <span class="text-primary font-bold text-sm">{t.name.charAt(0)}</span>
            </div>
            <div>
              <span class="block text-sm font-bold text-navy">{t.name}</span>
              <span class="text-xs text-navy/40">{t.location} · {t.service}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

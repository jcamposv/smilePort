---
import { getData, type Lang } from "../../data/i18n";

interface Props { lang?: Lang; }
const { lang = "en" } = Astro.props;
const { services } = getData(lang);
---

<section class="py-20 lg:py-28 bg-white" id={lang === "en" ? "services" : "servicios"}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="max-w-3xl mx-auto text-center mb-16 lg:mb-24">
      <span class="inline-flex items-center gap-2 bg-teal/10 text-teal-dark text-sm font-semibold px-4 py-1.5 rounded-full mb-5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8V7m0 10v1"/></svg>
        {lang === "en" ? "Same Quality, Fraction of the Price" : "Misma Calidad, Fracción del Precio"}
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight text-navy">
        {lang === "en" ? "Our Treatments" : "Nuestros Tratamientos"}
      </h2>
      <p class="mt-5 text-navy/50 text-lg font-body max-w-2xl mx-auto">
        {lang === "en" ? "We use the same FDA-approved materials and follow the same ADA protocols as top US clinics — at prices that make world-class dentistry accessible." : "Usamos los mismos materiales aprobados por la FDA y seguimos los mismos protocolos ADA que las mejores clínicas de EE.UU. — a precios que hacen accesible la odontología de clase mundial."}
      </p>
    </div>

    <!-- Services - alternating layout -->
    <div class="space-y-16 lg:space-y-24">
      {services.map((service, i) => (
        <div class={`grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center ${i % 2 !== 0 ? "lg:direction-rtl" : ""}`}>
          <!-- Image -->
          <div class={`relative ${i % 2 !== 0 ? "lg:order-2" : ""}`}>
            <div class="relative rounded-2xl lg:rounded-3xl overflow-hidden aspect-[4/3] shadow-xl shadow-navy/5">
              <img src={service.image} alt={service.title} class="w-full h-full object-cover" loading="lazy" />
              <!-- Savings badge -->
              <div class="absolute top-4 right-4 bg-teal text-white font-bold text-sm px-4 py-2 rounded-full shadow-lg">
                {lang === "en" ? "Save" : "Ahorra"} {service.savings}
              </div>
            </div>
            <!-- Price comparison floating card -->
            <div class="absolute -bottom-6 left-6 right-6 lg:left-8 lg:right-auto bg-white rounded-2xl shadow-xl shadow-navy/10 p-5 flex items-center gap-5 max-w-sm">
              <div class="text-center">
                <span class="text-xs text-navy/40 uppercase tracking-wider block">{lang === "en" ? "US Price" : "Precio EE.UU."}</span>
                <span class="text-red-400 line-through font-bold text-lg">{service.usPrice}</span>
              </div>
              <div class="w-px h-10 bg-gray-200"></div>
              <div class="text-center">
                <span class="text-xs text-teal uppercase tracking-wider font-semibold block">SmilePort</span>
                <span class="text-navy font-extrabold text-2xl">{service.price}</span>
              </div>
              <span class="text-[11px] text-navy/40">{lang === "en" ? "per tooth" : "por diente"}</span>
            </div>
          </div>

          <!-- Content -->
          <div class={`pt-8 lg:pt-0 ${i % 2 !== 0 ? "lg:order-1" : ""}`}>
            <div class="flex items-center gap-3 mb-4">
              <span class="text-5xl font-extrabold text-navy/5 font-sans">{service.index}</span>
              <div>
                <h3 class="text-2xl lg:text-3xl font-bold text-navy">{service.title}</h3>
                <p class="text-primary/60 text-sm font-medium">{service.titleEs}</p>
              </div>
            </div>

            <p class="text-navy/50 text-base lg:text-lg leading-relaxed font-body mb-6">
              {service.description}
            </p>

            <!-- Duration -->
            <div class="flex items-center gap-2 mb-6">
              <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span class="text-sm font-medium text-navy/60">{lang === "en" ? "Treatment time:" : "Tiempo de tratamiento:"} {service.duration}</span>
            </div>

            <!-- What's included -->
            <div class="bg-offwhite rounded-xl p-5 mb-6">
              <p class="text-xs font-semibold text-navy/40 uppercase tracking-wider mb-3">{lang === "en" ? "What's Included" : "Qué Incluye"}</p>
              <ul class="space-y-2.5">
                {service.includes.map((item) => (
                  <li class="flex items-center gap-3 text-sm text-navy/70 font-body">
                    <div class="w-5 h-5 rounded-full bg-teal/20 flex items-center justify-center shrink-0">
                      <svg class="w-3 h-3 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    {item}
                  </li>
                ))}
              </ul>
            </div>

            <button data-booking class="inline-flex items-center gap-2 bg-primary hover:bg-primary-dark text-white font-semibold rounded-full px-7 py-3.5 text-sm transition-all shadow-lg shadow-primary/20 cursor-pointer">
              {lang === "en" ? "Get a Free Quote" : "Cotización Gratis"}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </button>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom comparison banner -->
    <div class="mt-20 lg:mt-28 bg-navy rounded-3xl p-8 lg:p-12 text-center">
      <h3 class="text-2xl lg:text-3xl font-bold text-white mb-3">{lang === "en" ? "Why Pay More for the Same Quality?" : "¿Por qué pagar más por la misma calidad?"}</h3>
      <p class="text-white/60 font-body max-w-2xl mx-auto mb-8">
        {lang === "en" ? "Our specialists use the same FDA-approved materials (Straumann, Nobel Biocare, E-max) and follow ADA protocols. The only difference? You save thousands." : "Nuestros especialistas usan los mismos materiales aprobados por la FDA (Straumann, Nobel Biocare, E-max) y siguen protocolos ADA. ¿La única diferencia? Ahorras miles."}
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 max-w-3xl mx-auto">
        {services.map((s) => (
          <div class="text-center">
            <span class="block text-teal font-extrabold text-2xl">{s.price}</span>
            <span class="text-white/40 text-xs mt-1 block">{s.title}</span>
            <span class="text-red-400/60 text-xs line-through block">{s.usPrice} US</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
